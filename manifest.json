{
  "name": "Continue Later",
  "id": "continue-later-skill",
  "version": "1.0.0",
  "description": "Generate and manage project continuation documentation for seamless handoffs and knowledge preservation across coding sessions",
  "author": "Dhruv Anand",
  "license": "MIT",
  "homepage": "https://github.com/dhruv-anand-aintech/continue-later-skill",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhruv-anand-aintech/continue-later-skill"
  },
  "keywords": [
    "continuation",
    "handoff",
    "documentation",
    "project-management",
    "knowledge-preservation",
    "team-workflow",
    "cursor-skill"
  ],
  "categories": [
    "productivity",
    "documentation",
    "workflow"
  ],
  "triggers": [
    "hand this off",
    "continue later",
    "save project state",
    "create a continuation",
    "document where we left off",
    "resume from earlier",
    "what was I working on",
    "/continue-later-fast",
    "quick save",
    "just dump the context"
  ],
  "documentation": {
    "main": "skills/continue-later/SKILL.md",
    "example": "examples/continuation-example.md",
    "continueLaterFast": "skills/continue-later-fast/SKILL.md",
    "resumeContinuation": "skills/resume-continuation/SKILL.md",
    "install": "install.sh"
  },
  "features": [
    "One-command install via install.sh into ~/.cursor/skills",
    "continue-later: structured continuation.md",
    "continue-later-fast: raw git dump only",
    "resume-continuation: summarize existing continuation.md",
    "No marketplace, no npm—curl and bash only"
  ],
  "useCases": [
    "Team handoffs and transitions",
    "Long-running project documentation",
    "Onboarding new developers",
    "Knowledge preservation",
    "Architectural decision logging",
    "Gotcha and lesson tracking"
  ]
}
