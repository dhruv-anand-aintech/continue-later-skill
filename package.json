{
  "name": "create-continuation-skill",
  "version": "1.0.0",
  "description": "Generate comprehensive continuation.md handoff documentation for fresh development sessions. Perfect for handing off coding projects to new team members or resuming long-running tasks.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "create-continuation": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "node --test dist/**/*.test.js",
    "prepack": "npm run build",
    "format": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "continuation",
    "handoff",
    "documentation",
    "session-management",
    "project-memory",
    "ai-handoff",
    "development-workflow"
  ],
  "author": "Dhruv Anand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhruvanand/create-continuation-skill.git"
  },
  "bugs": {
    "url": "https://github.com/dhruvanand/create-continuation-skill/issues"
  },
  "homepage": "https://github.com/dhruvanand/create-continuation-skill#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "yaml": "^2.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
